#
# Archivo de configuración del Kernel de Linux 7.0.10
# Optimizado para QEMU/KVM + LFS 13.0 (systemd) + KDE Plasma (virgl)
#

#
# Configuración General y Requisitos de Subject (42)
#
CONFIG_LOCALVERSION="-shurtado"
# CONFIG_LOCALVERSION_AUTO is not set
CONFIG_DEFAULT_HOSTNAME="(none)"
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_CROSS_MEMORY_ATTACH=y
CONFIG_EXPERT=y
CONFIG_MULTIUSER=y

#
# Requisitos Críticos de Systemd
#
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y
# CONFIG_RT_GROUP_SCHED is not set
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_PSI=y
# CONFIG_PSI_DEFAULT_DISABLED is not set
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y
CONFIG_FHANDLE=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_SHMEM=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_FSNOTIFY=y

#
# Soporte de CPU y Virtualización (Host: AMD Ryzen AI 7 350 / Guest: x86_64)
#
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_GENERIC_CPU=y
CONFIG_SMP=y
CONFIG_NR_CPUS=16
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_PARAVIRT_SPINLOCKS=y
CONFIG_KVM_GUEST=y
CONFIG_X86_X2APIC=y
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_RELOCATABLE=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_CC_STACKPROTECTOR_STRONG=y

#
# Formatos de Ejecutable
#
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

#
# Redes (Network)
#
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_BT is not set
# CONFIG_RFKILL is not set
# CONFIG_HAMRADIO is not set
# CONFIG_CAN is not set

#
# Controladores de Dispositivos (Device Drivers)
# TODOS EN MODO BUILT-IN (=y), SIN MÓDULOS (=m)
#

# --- PCI & Base Virtio ---
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MENU=y

# --- Bloque (Block) y Almacenamiento ---
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_VIRTIO_BLK=y
# CONFIG_ATA is not set
# CONFIG_SATA_AHCI is not set
# CONFIG_BLK_DEV_NVME is not set
# CONFIG_BLK_DEV_SD is not set
# CONFIG_BLK_DEV_SR is not set
# CONFIG_BLK_DEV_FD is not set
# CONFIG_MD is not set
# CONFIG_BLK_DEV_DM is not set
# CONFIG_SCSI is not set

# --- Red (Network Devices) ---
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_VIRTIO_NET=y
# CONFIG_ETHERNET is not set
# CONFIG_NET_VENDOR_INTEL is not set
# CONFIG_NET_VENDOR_REALTEK is not set
# CONFIG_NET_VENDOR_BROADCOM is not set
# CONFIG_WLAN_VENDOR_INTEL is not set

# --- Entrada (Input) y Teclado/Ratón ---
CONFIG_INPUT=y
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_MOUSE=y
# CONFIG_MOUSE_PS2 is not set
CONFIG_INPUT_TABLET=y
CONFIG_VIRTIO_INPUT=y

# --- Consola (TTY & Console) ---
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_CONSOLE_TRANSLATIONS=y
CONFIG_VT_CONSOLE=y
CONFIG_HW_CONSOLE=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_UNIX98_PTYS=y

# --- Gráficos, Display y DRM (Preparado para KDE Plasma / Virgl) ---
CONFIG_HAS_IOMEM=y
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_BOCHS=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_FRAMEBUFFER_CONSOLE=y
# CONFIG_DRM_AMDGPU is not set
# CONFIG_DRM_RADEON is not set
# CONFIG_DRM_I915 is not set
# CONFIG_DRM_NOUVEAU is not set
# CONFIG_AGP is not set
# CONFIG_VGA_ARB is not set

# --- Sonido (Sound) ---
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_TIMER=y
CONFIG_SND_PCM=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_HDA_CODEC_GENERIC=y
CONFIG_SND_HDA_CORE=y
# CONFIG_SND_USB is not set

# --- Subisistemas COMPLETAMENTE Desactivados ---
# CONFIG_USB_SUPPORT is not set
# CONFIG_USB is not set
# CONFIG_MMC is not set
# CONFIG_I2C is not set
# CONFIG_SPI is not set
# CONFIG_HWMON is not set
# CONFIG_THERMAL is not set
# CONFIG_THUNDERBOLT is not set
# CONFIG_FIREWIRE is not set
# CONFIG_ACPI_BATTERY is not set
# CONFIG_ACPI_VIDEO is not set
# CONFIG_MACINTOSH_DRIVERS is not set
# CONFIG_INFINIBAND is not set
# CONFIG_STAGING is not set

#
# Sistemas de Archivos (Filesystems)
#
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_AUTOFS4_FS=y
CONFIG_FS_MBCACHE=y
CONFIG_JBD2=y
CONFIG_FS_POSIX_ACL=y
CONFIG_FILE_LOCKING=y

# --- Pseudo Sistemas de Archivos Críticos ---
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_KERNFS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- Sistemas de Archivos Desactivados ---
# CONFIG_BTRFS_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_FAT_FS is not set
# CONFIG_NTFS3_FS is not set
# CONFIG_NETWORK_FILESYSTEMS is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
# CONFIG_OVERLAY_FS is not set
# CONFIG_FUSE_FS is not set

#
# Seguridad, Criptografía y Debug
#
CONFIG_CRYPTO=y
CONFIG_CRYPTO_USER=y
# CONFIG_CRYPTO_HW is not set
# CONFIG_SECURITY_SELINUX is not set
# CONFIG_SECURITY_APPARMOR is not set

# --- Hacking y Debug Desactivado ---
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_INFO is not set
# CONFIG_FTRACE is not set
# CONFIG_KPROBES is not set
# CONFIG_DEBUG_FS is not set
# CONFIG_MAGIC_SYSRQ is not set
# CONFIG_KGDB is not set
# CONFIG_DEBUG_BUGVERBOSE is not set
# CONFIG_DEBUG_MISC is not set
# CONFIG_SLUB_DEBUG is not set
# CONFIG_PROVE_LOCKING is not set